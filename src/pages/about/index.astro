---
import { Spoiler, Timeline } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import Substats from '@/components/about/Substats.astro'
import ToolSection from '@/components/about/ToolSection.astro'

const headings = [
  { depth: 2, slug: 'hobbies', text: 'Hobbies' },
  { depth: 2, slug: 'tools', text: 'Tools' },
  { depth: 2, slug: 'social-networks', text: 'Social Networks' },
  { depth: 2, slug: 'about-blog', text: 'About Blog' }
]
---

<PageLayout title='About' {headings}>
  <p>Developer / Designer</p>
  <p>
    Hi — my real name is Yechen Liu (Yokohama Snowly online). I am a student at Rice University
    studying CS, Applied Math, and Neuroscience. I also work as a student researcher in Scientific
    Machine Learning (SciML) and as an intern at the Houston Asian American Archive. I care about
    computational science, chemistry, Asian immigrant histories in the U.S., Ming Dynasty history,
    and how governments organize themselves.
  </p>
  <p>
    My motto: 见诸相非相，即见如来. <Spoiler>你知道的太多了</Spoiler>
  </p>

  {/* general-talk */}
  <h2 id='hobbies'>Hobbies</h2>
  <ul>
    <li>
      Gaming
      <ul>
        <li>Battlefield V</li>
        <li>Battlefield I</li>
        <li>Cyberpunk 2077</li>
        <li>Hogwarts Legacy</li>
        <li>Genshin Impact</li>
        <li>Minecraft</li>
      </ul>
    </li>
    <li>
      Sports
      <ul>
        <li>Chess</li>
        <li>Fencing</li>
      </ul>
    </li>
  </ul>

  {/* tools */}
  <h2 id='tools'>Tools</h2>
  <p>Tools I reach for most often:</p>
  <ToolSection
    class='mb-5'
    title='Design'
    tools={[
      {
        name: 'Photoshop',
        description: 'Picture Editing',
        href: 'https://www.adobe.com/products/photoshop',
        icon: import('@/assets/tools/photoshop.svg?raw')
      },
      {
        name: 'Illustrator',
        description: 'Vector Drawing',
        href: 'https://www.adobe.com/products/illustrator',
        icon: import('@/assets/tools/illustrator.svg?raw')
      },
      {
        name: 'After Effects',
        description: 'Motion Graphics',
        href: 'https://www.adobe.com/products/aftereffects',
        icon: import('@/assets/tools/aftereffects.svg?raw')
      },
      {
        name: 'Premiere Pro',
        description: 'Video Editing',
        href: 'https://www.adobe.com/products/premiere',
        icon: import('@/assets/tools/premiere.svg?raw')
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='Productivity'
    tools={[
      {
        name: 'Chrome',
        description: 'Browser',
        href: 'https://www.google.com/chrome/',
        icon: import('@/assets/tools/chrome.svg?raw')
      },
      {
        name: 'Firefox',
        description: 'Browser',
        href: 'https://www.mozilla.org/en-US/firefox',
        icon: import('@/assets/tools/firefox.svg?raw')
      },
      {
        name: 'Notion',
        description: 'Note Taking',
        href: 'https://www.notion.so/',
        icon: import('@/assets/tools/notion.svg?raw')
      },
      {
        name: 'Typora',
        description: 'Markdown Editor',
        href: 'https://typora.io/',
        icon: import('@/assets/tools/typora.svg?raw')
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='Development'
    tools={[
      {
        name: 'VS Code',
        description: 'IDE',
        href: 'https://code.visualstudio.com/',
        icon: import('@/assets/tools/vscode.svg?raw')
      },
      {
        name: 'Cursor',
        description: 'IDE',
        href: 'https://www.cursor.com/',
        icon: import('@/assets/tools/cursor.svg?raw')
      },
      {
        name: 'Neovim',
        description: 'IDE',
        href: 'https://neovim.io/',
        icon: import('@/assets/tools/neovim.svg?raw')
      },
      {
        name: 'Sublime Text',
        description: 'IDE',
        href: 'https://www.sublimetext.com/',
        icon: import('@/assets/tools/sublime.svg?raw')
      },
      {
        name: 'Vim',
        description: 'Text Editor',
        href: 'https://www.vim.org/',
        icon: import('@/assets/tools/vim.svg?raw')
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='Environment'
    tools={[
      {
        name: 'Arch Linux',
        description: 'Linux Distribution',
        href: 'https://archlinux.org/',
        icon: import('@/assets/tools/archlinux.svg?raw')
      },
      {
        name: 'Ubuntu 24.04 LTS',
        description: 'Linux Distribution',
        href: 'https://ubuntu.com/',
        icon: import('@/assets/tools/ubuntu.svg?raw')
      },
      {
        name: 'MacOS Tahoe',
        description: 'MacBook Air',
        href: 'https://www.apple.com/macos/',
        icon: import('@/assets/tools/apple.svg?raw')
      },
      {
        name: 'Windows 11',
        description: 'ASUS ROG Strix G16 (2025)',
        href: 'https://news.microsoft.com/windows11-general-availability/',
        icon: import('@/assets/tools/windows11.svg?raw')
      }
    ]}
  />

  {/* social-networks */}
  <h2 id='social-networks'>Social Networks</h2>
  <p>Find me on GitHub for code, or Steam when I am between problem sets.</p>
  <Substats
    stats={[
      {
        platform: 'GitHub',
        icon: 'github',
        link: 'https://github.com/user309dec',
        text: 'followers',
        api: 'github/user309dec'
      },
      {
        platform: 'Steam',
        icon: 'steam',
        color: '#50769d',
        link: 'https://steamcommunity.com/id/fkin_amazing',
        text: 'games',
        api: 'steamgames/76561199021278120'
      }
    ]}
  />

  {/* about-blog */}
  <h2 id='about-blog'>About Blog</h2>
  <p>Website history:</p>
  <Timeline
    events={[
      {
        date: '2025-09-23',
        content: 'Started publishing more personal thoughts and research notes.'
      },
      {
        date: '2024-09-22',
        content:
          'Site rebuilt with <a href="https://astro.build/" target="_blank" rel="noopener noreferrer">Astro</a> and <a href="https://github.com/cworld1/astro-theme-pure" target="_blank" rel="noopener noreferrer">Astro Theme Pure</a>.'
      },
      {
        date: '2024-09-20',
        content:
          'Published at <a href="https://user309dec.github.io/YokohamaSnowlyBlog/" target="_blank" rel="noopener noreferrer">user309dec.github.io/YokohamaSnowlyBlog</a>.'
      }
    ]}
  />
  <p>
    The smooth operation and personalized customization of this site also rely on the resources and
    technical support provided by the following projects and services:
  </p>
  <ul>
    <li>
      Domain & hosting: <a href='https://pages.github.com/' target='_blank' rel='noopener noreferrer'
        >GitHub Pages</a
      >
    </li>
    <li>
      Framework & Theme: <a href='https://astro.build/' target='_blank' rel='noopener noreferrer'
        >Astro</a
      > + <a
        href='https://github.com/cworld1/astro-theme-pure'
        target='_blank'
        rel='noopener noreferrer'>Astro Theme Pure</a
      >
    </li>
    <li>
      Other statistics: <a
        href='https://github.com/spencerwooo/substats'
        target='_blank'
        rel='noopener noreferrer'>Substats</a
      >
    </li>
  </ul>
</PageLayout>
